# The site runs fully WITHOUT any of these. They unlock phase-2 features.

# Public site URL (used in metadata / canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Booking notifications (optional). If RESEND_API_KEY is set, the /api/book
# route emails inquiries; otherwise it just records them to the server log.
RESEND_API_KEY=
BOOKING_NOTIFY_EMAIL=bookings@afterhouse.agency

# --- Payload CMS (payload-cms branch) ---
# Flip the site's data source to the CMS (default off = static lib/content.ts).
USE_CMS=false
# Local dev uses SQLite by default; for production use a Postgres/LibSQL URL.
DATABASE_URI=file:./afterhouse.db
# Required by Payload — use a long random string (min 32 chars).
PAYLOAD_SECRET=
