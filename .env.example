# The site runs fully WITHOUT any of these. They unlock phase-2 features.

# Public site URL (used in metadata / canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Booking notifications (optional). If RESEND_API_KEY is set, the /api/book
# route emails inquiries; otherwise it just records them to the server log.
RESEND_API_KEY=
BOOKING_NOTIFY_EMAIL=bookings@afterhouse.agency
